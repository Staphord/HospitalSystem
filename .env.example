# ──────────────────────────────────────────────
# Hospital Flow — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Application
ENVIRONMENT=dev                          # dev | staging | prod
SECRET_KEY=change_me_to_a_random_secret  # Used for internal signing; 32+ chars
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8501  # Comma-separated CORS origins

# Database (Master DB — stores tenants, users, subscriptions)
DATABASE_URL=postgresql://postgres:nasr@localhost:5432/hospital-db

# Redis (session cache, rate limiting, token blacklist)
REDIS_URL=redis://localhost:6379/0

# Keycloak (OIDC provider)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hospital-realm
KEYCLOAK_CLIENT_ID=hospital-api
KEYCLOAK_CLIENT_SECRET=change_me_to_a_secure_client_secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_to_a_secure_admin_password

# When true, every API call introspects the token with Keycloak.
# Use in prod to instantly revoke access when a user is disabled.
# In dev you can set to false to reduce Keycloak load.
KEYCLOAK_INTROSPECT=true

# Multi-tenant
DEFAULT_HOSPITAL_ID=default-hospital

# Password reset token expiry (seconds)
PASSWORD_RESET_TOKEN_TTL=3600
