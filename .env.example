# ──────────────────────────────────────────────
# Hospital Flow — Microservices Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Application
ENVIRONMENT=dev                          # dev | staging | prod
SECRET_KEY=change_me_to_a_random_secret  # Used for internal signing; 64+ chars
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8501  # Comma-separated CORS origins

# Database (Master DB — stores tenants, users, subscriptions, super admins)
MASTER_DB_URL=postgresql://postgres:nasr@localhost:5432/hospital-db

# PostgreSQL Admin (for creating new tenant databases)
# Must have CREATEDB privilege. Same as MASTER_DB_URL if the user has CREATEDB.
DB_ADMIN_URL=postgresql://postgres:nasr@localhost:5432/postgres

# Tenant database naming
# {tenant_id} will be replaced with the actual tenant ID (e.g., hosp-a1b2c3d4)
TENANT_DB_TEMPLATE=postgresql://postgres:nasr@localhost:5432/tenant_{tenant_id}

# Redis (session cache, rate limiting, token blacklist, tenant suspension blocklist, JWKS cache)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (event bus between services)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# SMTP (transactional emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change_me_to_a_secure_smtp_password

# Keycloak (OIDC provider)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hospital-realm
KEYCLOAK_CLIENT_ID=hospital-api
KEYCLOAK_CLIENT_SECRET=change_me_to_a_secure_client_secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_to_a_secure_admin_password

# When true, every API call introspects the token with Keycloak.
# Use in prod to instantly revoke access when a user is disabled.
# In dev you can set to false to reduce Keycloak load.
KEYCLOAK_INTROSPECT=true

# Multi-tenant
DEFAULT_HOSPITAL_ID=default-hospital

# Tenant DB encryption key (32-byte base64-encoded key for Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TENANT_DB_ENCRYPTION_KEY=ZXlKcGMzUWlPaUprYVhOamRXVnpZM0psY3lJc0luTjFZaUk2SWpFaUxDSnVZVzFsSWpvaU1EQWlMQ0pqYldGMFpXNTBYM1I1Y0dVaU9pSXhNREFpTENKemVtRnRaU0k2SWpFd01D

# Impersonation token TTL (seconds, default 15 minutes)
IMPERSONATION_TOKEN_TTL=900

# Suspension check interval (seconds, default 24 hours)
SUSPENSION_CHECK_INTERVAL=86400

# Suspended tenant blocklist TTL (seconds, default 1 hour)
SUSPENDED_BLOCKLIST_TTL=3600

# ──────────────────────────────────────────────
# Service URLs (used by API Gateway and inter-service calls)
# ──────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8001
MASTER_SERVICE_URL=http://localhost:8002
RECEPTION_SERVICE_URL=http://localhost:8010
TRIAGE_SERVICE_URL=http://localhost:8011
CONSULTATION_SERVICE_URL=http://localhost:8012
LABORATORY_SERVICE_URL=http://localhost:8013
RADIOLOGY_SERVICE_URL=http://localhost:8014
PHARMACY_SERVICE_URL=http://localhost:8015
BILLING_SERVICE_URL=http://localhost:8016
WARD_SERVICE_URL=http://localhost:8017
ADMIN_SERVICE_URL=http://localhost:8018
NOTIFICATION_SERVICE_URL=http://localhost:8019
REPORT_SERVICE_URL=http://localhost:8020

# Password reset token expiry (seconds)
PASSWORD_RESET_TOKEN_TTL=3600
