# ──────────────────────────────────────────────
# Auth Service — Environment Configuration
# ──────────────────────────────────────────────

ENVIRONMENT=dev
SECRET_KEY=change_me_to_a_random_secret
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8501

# Database (Master DB — stores tenants, users, subscriptions)
DATABASE_URL=postgresql://postgres:nasr@localhost:5432/hospital-db

# Redis (session cache, rate limiting, token blacklist, tenant suspension blocklist)
REDIS_URL=redis://localhost:6379/0

# Keycloak (OIDC provider)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hospital-realm
KEYCLOAK_CLIENT_ID=hospital-api
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
KEYCLOAK_INTROSPECT=true

# Multi-tenant
DEFAULT_HOSPITAL_ID=default-hospital

# Password reset token expiry (seconds)
PASSWORD_RESET_TOKEN_TTL=3600

# Tenant DB encryption key (32-byte base64-encoded key for Fernet)
TENANT_DB_ENCRYPTION_KEY=ZXlKcGMzUWlPaUprYVhOamRXVnpZM0psY3lJc0luTjFZaUk2SWpFaUxDSnVZVzFsSWpvaU1EQWlMQ0pqYldGMFpXNTBYM1I1Y0dVaU9pSXhNREFpTENKemVtRnRaU0k2SWpFd01D

# Impersonation token TTL (seconds, default 15 minutes)
IMPERSONATION_TOKEN_TTL=900

# Suspension check interval (seconds, default 24 hours)
SUSPENSION_CHECK_INTERVAL=86400

# Suspended tenant blocklist TTL (seconds, default 1 hour)
SUSPENDED_BLOCKLIST_TTL=3600
